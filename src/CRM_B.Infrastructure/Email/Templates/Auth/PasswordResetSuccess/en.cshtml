@model CRM_B.Application.Emails.Auth.PasswordResetSuccessEmailModel

<h2 style="color: #1a1a2e; margin: 0 0 16px; font-size: 20px;">Password reset successful</h2>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Hi @Model.FullName,
</p>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Your password has been reset successfully. You can now log in with your new password.
</p>

<p style="color: #8e8ea0; font-size: 14px; line-height: 1.6; margin: 0;">
    If you did not make this change, please contact our support team immediately to secure your account.
</p>
