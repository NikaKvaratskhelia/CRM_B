@model CRM_B.Application.Emails.Auth.WelcomeEmailModel

<h2 style="color: #1a1a2e; margin: 0 0 16px; font-size: 20px;">Welcome to GRA!</h2>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Hi @Model.FullName,
</p>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Your email has been verified successfully. Welcome aboard! We're excited to have you as part of the GRA community.
</p>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    You can now explore events, courses, and more. Get started by logging in to your account.
</p>

<p style="color: #8e8ea0; font-size: 14px; line-height: 1.6; margin: 0;">
    If you have any questions, feel free to reach out to our support team.
</p>
