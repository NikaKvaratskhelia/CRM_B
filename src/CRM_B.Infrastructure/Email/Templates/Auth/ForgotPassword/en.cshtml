@model VS_ARC.Application.Emails.Auth.ForgotPasswordEmailModel

<h2 style="color: #1a1a2e; margin: 0 0 16px; font-size: 20px;">Reset your password</h2>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Hi @Model.FullName,
</p>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    We received a request to reset your password. Use the code below to proceed.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 32px;">
    <tr>
        <td align="center">
            <div style="background-color: #f4f4f7; border-radius: 8px; padding: 20px 32px; display: inline-block; letter-spacing: 6px; font-size: 32px; font-weight: 700; color: #1a1a2e;">
                @Model.Token
            </div>
        </td>
    </tr>
</table>

<p style="color: #51545e; font-size: 16px; line-height: 1.6; margin: 0 0 24px;">
    Or click the button below to reset your password directly:
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 32px;">
    <tr>
        <td align="center">
            <a href="@Model.ResetUrl"
               style="background-color: #1a1a2e; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 6px; font-size: 16px; font-weight: 600; display: inline-block;">
                Reset Password
            </a>
        </td>
    </tr>
</table>

<p style="color: #8e8ea0; font-size: 14px; line-height: 1.6; margin: 0 0 8px;">
    This code expires in 15 minutes. If you did not request a password reset, please ignore this email.
</p>

<p style="color: #8e8ea0; font-size: 14px; line-height: 1.6; margin: 0;">
    If you did not make this request, your account is still safe and no changes have been made.
</p>
